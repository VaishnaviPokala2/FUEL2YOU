CREATE TABLE users(
id INTEGER PRIMARY KEY AUTOINCREMENT,
name TEXT,
email TEXT,
password TEXT,
role TEXT
);

CREATE TABLE fuel_price(
id INTEGER PRIMARY KEY AUTOINCREMENT,
fuel TEXT,
price REAL
);

CREATE TABLE orders(
id INTEGER PRIMARY KEY AUTOINCREMENT,
user TEXT,
fuel TEXT,
quantity REAL,
total REAL,
address TEXT,
payment TEXT,
status TEXT
);

